# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Environment variables (keep secrets out of git) ───────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Production builds ─────────────────────────────────────────────────────────
/build
**/build/
/dist
**/dist/

# ── Testing / Coverage ────────────────────────────────────────────────────────
/coverage
**/coverage/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Yarn ──────────────────────────────────────────────────────────────────────
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ── Uploads (user-generated content, not tracked) ─────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep
